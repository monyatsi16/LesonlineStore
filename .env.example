# ============================================================
#  LesOnline — Environment Variables
#  Copy this file to .env and fill in your real values
# ============================================================

# ── Database (Neon PostgreSQL) ──────────────────────────────
# Get this from https://neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Session ─────────────────────────────────────────────────
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# ── Node Environment ─────────────────────────────────────────
NODE_ENV=production

# ── Port (Railway sets this automatically — do not change) ───
# PORT=5000

# ── Email / SMTP (for order notifications) ──────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=LesOnline
SMTP_FROM_EMAIL=no-reply@lesonline.co.ls

# ── Stripe (optional — for card payments) ───────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── AI / Pricing (optional) ─────────────────────────────────
# OPENAI_API_KEY=sk-...
